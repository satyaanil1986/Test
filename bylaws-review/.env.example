# Copy this file to .env and fill in real values. Never commit .env.

# --- Google Sheets (service account) ---
# Paste the full JSON key content on one line, OR set GOOGLE_SERVICE_ACCOUNT_FILE
# to a path instead.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=

# Sheet ID is the long id in the sheet URL between /d/ and /edit
SPREADSHEET_ID=1P2IG4yRPfUq7VVsfUMF_Vg0TzY3kspVg16JSqTmYpkA
# Range without a sheet name defaults to the first tab in the spreadsheet.
SHEET_RANGE=A:F

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Reference document ---
BYLAWS_DOCX_PATH=bylaws-review/bylaws.docx
